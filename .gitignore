styles/concept-art/
styles/concept-art2/
styles/*.png
styles/*.jpg
styles/*.jpeg
styles/*.webp
styles/*.gif
styles/src/**/*.png
styles/src/**/*.jpg
styles/src/**/*.webp
styles/node_modules/

